rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Users collection: profiles and roles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['email', 'displayName']);
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Organizer requests: created by signed-in users; status updates by admins only
    match /organizer_requests/{requestId} {
      // Users can create requests
      allow create: if isSignedIn();

      // Users can read (list/read) their own requests or admins can read all
      allow read: if isSignedIn();

      // Only admins can update the status (approve/reject)
      allow update: if isAdmin();

      // Optional: only admins can delete
      allow delete: if isAdmin();
    }

    // Events: require ownership and organizer role for creation
    match /events/{eventId} {

      function getUserRole() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      }

      function isOrganizer() {
        return isSignedIn() && (getUserRole() == 'organizer' || getUserRole() == 'admin');
      }

      // Anyone signed-in can read events
      allow read: if isSignedIn();

      // Create: only organizers; require ownership fields and createdAt timestamp
      allow create: if isOrganizer()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.createdAt is timestamp;

      // Update: owner (createdBy) or admin can update; disallow changing createdBy
      allow update: if isSignedIn() && ((resource.data.createdBy == request.auth.uid)
        || (getUserRole() == 'admin'))
        && request.resource.data.createdBy == resource.data.createdBy;

      // Delete: owner or admin
      allow delete: if isSignedIn() && ((resource.data.createdBy == request.auth.uid)
        || (getUserRole() == 'admin'));
    }

    // Bookings nested under events
    match /events/{eventId}/bookings/{bookingId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid
        || get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid
        || get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid);
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
