rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: one document per authenticated user at /users/{uid}
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['email', 'displayName']);
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Events: top-level collection. Read is public; writes restricted to organizer.
    match /events/{eventId} {
      allow read: if true;

      function isValidEvent(data) {
        return data.title is string
          && data.title.size() > 0
          && data.title.size() <= 300
          && (data.date is timestamp)
          && (data.location is string)
          && data.location.size() <= 300
          && (data.organizerId is string)
          && (data.price is number || !('price' in data))
          && (!('bookings' in data) || (data.bookings is int && data.bookings >= 0))
          && (!('colors' in data) || (data.colors is list));
      }

      allow create: if request.auth != null
        && request.resource.data.organizerId == request.auth.uid
        && isValidEvent(request.resource.data)
        && request.resource.data.keys().hasAny(['title', 'date', 'location', 'organizerId']);

      allow update: if request.auth != null
        && resource.data.organizerId == request.auth.uid
        && isValidEvent(request.resource.data);

      allow delete: if request.auth != null
        && resource.data.organizerId == request.auth.uid;

      // Bookings subcollection is handled below
    }

    // Bookings per event: only authenticated users may create a booking for themselves.
    match /events/{eventId}/bookings/{bookingId} {
      function isValidBooking(data) {
        return data.userId is string
          && (data.createdAt is timestamp || !('createdAt' in data));
      }

      // Create: only authenticated users can create bookings for themselves; createdAt must be a timestamp
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && isValidBooking(request.resource.data);

      // Read: booking owner or event organizer
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid);

      // Delete: booking owner or event organizer
      allow delete: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid);
    }

    // Deny access to any other top-level documents by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles: users/{userId}
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Events collection: events/{eventId}
    // - Reads are public (adjust to `request.auth != null` if you require auth)
    // - Creates must set `organizerId` equal to the authenticated UID
    // - Updates/deletes allowed only when the stored organizerId matches the authenticated UID
    match /events/{eventId} {
      allow read: if true;

      allow create: if request.auth != null
                     && request.resource.data.organizerId == request.auth.uid;

      allow update, delete: if request.auth != null
                            && resource.data.organizerId == request.auth.uid;
    }
  }
}
